    items.forEach(function (item) { options.push('<option value="' + escapeHTML(String(item[valueKey] || "")) + '">' + escapeHTML(labelBuilder(item)) + '</option>'); });
    select.innerHTML = options.join("");
    if (currentValue) select.value = currentValue;
  }

