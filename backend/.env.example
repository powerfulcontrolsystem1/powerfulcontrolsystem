# Variables de entorno necesarias para el backend
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=https://powerfulcontrolsystem.com/auth/google/callback
# Clave de cifrado para secretos sensibles (base64 recomendado, 32 bytes)
CONFIG_ENC_KEY=replace-with-base64-32-byte-key
DB_PATH=pos.db
DB_DIALECT=postgres
DB_EMPRESAS_DSN=postgres://user:pass@127.0.0.1:5432/pcs_empresas?sslmode=disable
DB_SUPERADMIN_DSN=postgres://user:pass@127.0.0.1:5432/pcs_superadministrador?sslmode=disable
DB_VPS_TUNNEL_ENABLED=0
DB_VPS_SSH_HOST=
DB_VPS_SSH_USER=
DB_VPS_SSH_KEY_PATH=../clave privada ssh.ppk
DB_VPS_LOCAL_PORT=15432
DB_VPS_REMOTE_HOST=127.0.0.1
DB_VPS_REMOTE_PORT=5432
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VPS_TUNNEL_ENABLED=0
OLLAMA_VPS_SSH_HOST=
OLLAMA_VPS_SSH_USER=
OLLAMA_VPS_SSH_KEY_PATH=../clave privada ssh.ppk
OLLAMA_VPS_LOCAL_PORT=11435
OLLAMA_VPS_REMOTE_HOST=127.0.0.1
OLLAMA_VPS_REMOTE_PORT=11434
