# Variables de entorno necesarias para el backend
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
GOOGLE_REDIRECT_URL=https://powerfulcontrolsystem.com/auth/google/callback
# Clave de cifrado para secretos sensibles (base64 recomendado, 32 bytes)
CONFIG_ENC_KEY=<BASE64_DE_32_BYTES>
CONFIG_ENC_KEY_PREVIOUS=
DB_DIALECT=postgres
DB_EMPRESAS_DSN=postgres://user:pass@127.0.0.1:5432/pcs_empresas?sslmode=disable
DB_SUPERADMIN_DSN=postgres://user:pass@127.0.0.1:5432/pcs_superadministrador?sslmode=disable
DB_VPS_TUNNEL_ENABLED=0
DB_VPS_SSH_HOST=
DB_VPS_SSH_USER=
DB_VPS_SSH_KEY_PATH=../clave privada ssh.ppk
DB_VPS_SSH_PORT=49222
DB_VPS_LOCAL_PORT=15432
DB_VPS_REMOTE_HOST=127.0.0.1
DB_VPS_REMOTE_PORT=5432
GEMINI_API_KEY=
# reCAPTCHA: por defecto usamos v2 checkbox (api.js).
# Si tus llaves son reCAPTCHA Enterprise, configura provider y el frontend cargará enterprise.js.
RECAPTCHA_PROVIDER=google-recaptcha-v2
GOOGLE_RECAPTCHA_SITE_KEY=<RECAPTCHA_SITE_KEY>
GOOGLE_RECAPTCHA_SECRET_KEY=<RECAPTCHA_SECRET_KEY>
RECAPTCHA_DEV_BYPASS=0
# Orquestador IA empresarial: mantener apagado hasta habilitar y probar cada
# herramienta por empresa. Generar secretos con: openssl rand -base64 32
AI_ENTERPRISE_ORCHESTRATOR_ENABLED=false
AI_WRITE_TOOLS_ENABLED=false
AI_HOTEL_TOOLS_ENABLED=false
AI_CATALOG_TOOLS_ENABLED=false
AI_AGENT_MODE_ENABLED=false
