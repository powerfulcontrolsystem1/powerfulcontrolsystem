# Copia este archivo como deploy/.env.platform y cambia secretos antes de levantar.
TZ=America/Bogota

# Dominio publico actual del VPS
PUBLIC_BASE_URL=https://powerfulcontrolsystem.com
GOOGLE_REDIRECT_URL=https://powerfulcontrolsystem.com/auth/google/callback
# En la VPS actual Nginx ya ocupa 80/443. Docker se levanta en paralelo y
# Nginx del host se conmuta despues de validar.
HTTP_BIND=127.0.0.1
HTTP_PORT=8081

# Edge Docker publico. Activalo con deploy/scripts/vps-docker-edge-up.sh
# cuando quieras que 80/443 queden dentro del stack Docker.
EDGE_DOMAIN=powerfulcontrolsystem.com
EDGE_WWW_DOMAIN=www.powerfulcontrolsystem.com
EDGE_ONLYOFFICE_DOMAIN=onlyoffice.powerfulcontrolsystem.com
EDGE_CERT_NAME=powerfulcontrolsystem.com
EDGE_CERT_EMAIL=admin@powerfulcontrolsystem.com
EDGE_CERT_EXTRA_DOMAINS=onlyoffice.powerfulcontrolsystem.com
EDGE_HTTP_BIND=0.0.0.0
EDGE_HTTPS_BIND=0.0.0.0
EDGE_NGINX_TEMPLATE=./nginx/edge.conf.template

# PostgreSQL interno de la plataforma
POSTGRES_USER=pcs
# Usa caracteres URL-safe aqui porque el backend forma un DSN PostgreSQL.
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DEFAULT_DB=pcs_superadministrador

# Debe ser base64 de 32 bytes o una cadena fuerte de 32+ caracteres.
CONFIG_ENC_KEY=change-me-32-byte-or-base64-key

# OAuth / IA / reCAPTCHA
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
OPENAI_API_KEY=
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
RECAPTCHA_PROVIDER=google-recaptcha-v2
RECAPTCHA_DEV_BYPASS=0

# OnlyOffice
ONLYOFFICE_TAG=latest
ONLYOFFICE_JWT_SECRET=change-me-onlyoffice-jwt
ONLYOFFICE_DOCUMENT_SERVER_URL=https://onlyoffice.powerfulcontrolsystem.com
ONLYOFFICE_BIND=127.0.0.1
ONLYOFFICE_PORT=8088

# Voz IA streaming
VOICE_STREAM_BASE_URL=http://voice-stream:8000
VOICE_STREAM_ENABLED=true
VOICE_STREAM_AUTH_HEADER=X-PCS-Voice-Token
VOICE_STREAM_AUTH_TOKEN=
VOICE_STREAM_MODEL_DIR=/models
VOICE_STREAM_MODEL_NAME=es_ES-sharvard-medium
VOICE_STREAM_MODEL_BASE_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/es/es_ES/sharvard/medium
VOICE_STREAM_MAX_CHARS=4000
VOICE_STREAM_TTS_TIMEOUT=20
VOICE_STREAM_BIND=127.0.0.1
VOICE_STREAM_PORT=8011
VOICE_STREAM_TTS_MODEL=
VOICE_STREAM_TTS_CONFIG=

# RustDesk. Abre 21115-21117 hacia Internet solo si vas a usar el servidor propio.
RUSTDESK_TAG=latest
RUSTDESK_BIND=0.0.0.0

# Nombres de imagen para migracion futura a otro VPS/registry.
PCS_BACKEND_IMAGE=pcs-backend:local
PCS_FRONTEND_IMAGE=pcs-frontend:local
PCS_VOICE_STREAM_IMAGE=pcs-voice-stream:local
