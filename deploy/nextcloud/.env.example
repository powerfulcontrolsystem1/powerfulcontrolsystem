# Copiar como deploy/nextcloud/.env en el VPS. No guardar secretos aqui.
NEXTCLOUD_BIND=127.0.0.1
NEXTCLOUD_PORT=8090
NEXTCLOUD_DATA_PATH=/srv/nextcloud/data
NEXTCLOUD_TRUSTED_DOMAINS=nube.example.com
NEXTCLOUD_OVERWRITE_HOST=nube.example.com
NEXTCLOUD_OVERWRITE_CLI_URL=https://nube.example.com
NEXTCLOUD_TRUSTED_PROXIES=172.16.0.0/12
NEXTCLOUD_DB_PASSWORD_FILE=/root/powerfulcontrolsystem-secrets/nextcloud_db_password
NEXTCLOUD_ADMIN_USER=pcs_nextcloud_admin
NEXTCLOUD_ADMIN_PASSWORD_FILE=/root/powerfulcontrolsystem-secrets/nextcloud_admin_password
NEXTCLOUD_REDIS_PASSWORD_FILE=/root/powerfulcontrolsystem-secrets/nextcloud_redis_password
