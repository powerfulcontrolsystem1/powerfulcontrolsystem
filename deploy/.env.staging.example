TZ=America/Bogota

POSTGRES_USER=pcs_staging
POSTGRES_PASSWORD=<POSTGRES_PASSWORD_STAGING_URL_SAFE>
POSTGRES_DEFAULT_DB=pcs_superadministrador
CONFIG_ENC_KEY=<BASE64_DE_32_BYTES>
CONFIG_ENC_KEY_ID=<ID_DE_CLAVE_STAGING>
CONFIG_ENC_KEY_PREVIOUS=
PCS_ENV=staging
PCS_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
PCS_CSRF_ALLOWED_ORIGINS=https://staging.powerfulcontrolsystem.com
PCS_CSP_IMG_ORIGINS=
PCS_CSP_CONNECT_ORIGINS=
PCS_CSP_FRAME_ORIGINS=
PCS_CSP_SCRIPT_ORIGINS=
SESSION_TIMEOUT=2h
MAX_REQUEST_BODY_BYTES=67108864
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=60s
HTTP_IDLE_TIMEOUT=2m
PCS_WEBRTC_IDLE_TIMEOUT_SECONDS=300
PCS_PRIVATE_STORAGE_DIR=/app/private_storage

PUBLIC_BASE_URL=https://staging.powerfulcontrolsystem.com
GOOGLE_REDIRECT_URL=https://staging.powerfulcontrolsystem.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GEMINI_API_KEY=
OPENAI_API_KEY=

GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=
RECAPTCHA_PROVIDER=google-recaptcha-v2
RECAPTCHA_DEV_BYPASS=1

HTTP_BIND=127.0.0.1
HTTP_PORT=8082
EDGE_DOMAIN=staging.powerfulcontrolsystem.com
EDGE_WWW_DOMAIN=
EDGE_ONLYOFFICE_DOMAIN=onlyoffice-staging.powerfulcontrolsystem.com
EDGE_CERT_NAME=staging.powerfulcontrolsystem.com
EDGE_CERT_EMAIL=admin@powerfulcontrolsystem.com
EDGE_CERT_EXTRA_DOMAINS=onlyoffice-staging.powerfulcontrolsystem.com
EDGE_HTTP_BIND=0.0.0.0
EDGE_HTTPS_BIND=0.0.0.0
EDGE_NGINX_TEMPLATE=./nginx/edge.conf.template

PCS_BACKEND_IMAGE=pcs-backend:staging
PCS_FRONTEND_IMAGE=pcs-frontend:staging

ONLYOFFICE_TAG=9.4
ONLYOFFICE_JWT_SECRET=<SECRETO_ALEATORIO_ONLYOFFICE_STAGING>
RUSTDESK_TAG=1.1.15
