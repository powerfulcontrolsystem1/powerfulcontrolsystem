{
  "uid": "pcs-operacion",
  "title": "Powerful Control System - Operacion VPS",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["pcs", "vps", "docker"],
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU VPS (%)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries",
      "title": "Memoria usada (%)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries",
      "title": "Disco usado (%)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs\"} * 100) / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs\"})",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries",
      "title": "Contenedores Docker - CPU",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by(name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "type": "stat",
      "title": "Backend producción arriba",
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 5},
      "targets": [
        {
          "expr": "up{job=\"pcs-backend\"}",
          "legendFormat": "production"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Backend staging arriba",
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 5},
      "targets": [
        {
          "expr": "up{job=\"pcs-staging-backend\"}",
          "legendFormat": "staging"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Contenedores activos",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 5},
      "targets": [
        {
          "expr": "count(container_last_seen{name!=\"\"})",
          "legendFormat": "containers"
        }
      ]
    }
  ]
}
